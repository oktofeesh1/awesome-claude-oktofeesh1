{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "predev": "node ../../scripts/build-content-index.mjs",
    "prebuild": "node ../../scripts/build-content-index.mjs",
    "pretype-check": "node ../../scripts/build-content-index.mjs",
    "prepreview": "node ../../scripts/build-content-index.mjs",
    "predeploy": "node ../../scripts/build-content-index.mjs",
    "predeploy:dev": "node ../../scripts/build-content-index.mjs",
    "predeploy:prod": "node ../../scripts/build-content-index.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply SITE_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply SITE_DB --remote",
    "preview": "vite build && wrangler dev --config wrangler.jsonc",
    "deploy": "pnpm run deploy:prod",
    "deploy:dev": "vite build && wrangler deploy --config wrangler.jsonc --env dev",
    "deploy:prod": "vite build && wrangler deploy --config wrangler.jsonc --env \"\""
